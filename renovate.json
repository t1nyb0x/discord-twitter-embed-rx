{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranches": ["develop"],
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "7 days",
  "postUpdateOptions": [
    "npmDedupe"
  ],
  "cloneSubmodules": true,
  "packageRules": [
    {
      "matchManagers": ["git-submodules"],
      "minimumReleaseAge": null
    }
  ]
}
