{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/apps/oxlint/schemas/oxlintrc_0_0.json",
  "env": {
    "node": true,
    "es2024": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    "*.config.*",
    "*.mjs",
    "dashboard/**",
    "packages/**",
    "tests/**"
  ],
  "plugins": ["typescript"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "typescript/no-explicit-any": "warn",
    "typescript/no-unused-vars": "warn"
  }
}
