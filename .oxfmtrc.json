{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "sortImports": true,
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    "dashboard/**",
    "packages/**",
    "tests/**"
  ]
}
